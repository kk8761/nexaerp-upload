  evmReports      ProjectEVM[]
  invoices        ProjectInvoice[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  
  @@index([status])
  @@index([projectType])
  @@index([projectManagerId])
  @@index([customerId])
  @@index([startDate])
}

// Project Cost Tracking model
model ProjectCost {
  id              String   @id @default(uuid())
  projectId       String
  
  // Cost details
  costType        String   @db.VarChar(50) // labor, material, equipment, overhead, other
  description     String   @db.Text
  amount          Float
  date            DateTime
  
  // References
  phaseId         String?  @db.VarChar(100) // Reference to phase in Project.phases JSON
  taskId          String?  @db.VarChar(100) // Reference to task in phase
  resourceId      String?  @db.VarChar(100) // Reference to resource in Project.resources JSON
  invoiceId       String?  // Reference to external invoice
  
  notes           String?  @db.Text
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  
  @@index([projectId, date])
  @@index([costType])
  @@index([date])
}

// Earned Value Management (EVM) model
model ProjectEVM {
  id              String   @id @default(uuid())
  projectId       String
  reportDate      DateTime
  
  // EVM Metrics (stored as JSON for flexibility)
  metrics         Json     // Contains: PV, EV, AC, CV, SV, CPI, SPI, EAC, ETC, VAC, BAC
  
  completionPercentage Float
  notes           String?  @db.Text
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  
  @@index([projectId, reportDate])
  @@index([reportDate])
}

// Project Invoice model
model ProjectInvoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   @unique @db.VarChar(100)
  projectId       String
  
  // Customer information
  customerId      String
  customerName    String   @db.VarChar(255)
  
  // Billing details
  billingType     String   @db.VarChar(50) // time_and_materials, milestone, fixed_price
  startDate       DateTime
  endDate         DateTime
  
  // Amounts
  subtotal        Float
  taxAmount       Float    @default(0)
  total           Float
  
  // Status
  status          String   @default("draft") @db.VarChar(50) // draft, sent, paid, overdue, cancelled
  dueDate         DateTime
  paidDate        DateTime?
  
  // Line items (stored as JSON)
  lineItems       Json     // Array of ProjectInvoiceLineItem objects
  
  notes           String?  @db.Text
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  
  @@index([projectId])
  @@index([status])
  @@index([customerId])
  @@index([dueDate])
}

// Project Template model
model ProjectTemplate {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  
  projectType     String   @db.VarChar(50) // internal, customer_project, capital_project, research
  defaultDuration Int      // in days
  
  // Template structure (stored as JSON)
  phases          Json     // Array of phase templates
  milestones      Json     // Array of milestone templates
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  
  @@index([projectType, isActive])
}
